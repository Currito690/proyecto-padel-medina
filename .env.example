# ============================================================================
# Variables de entorno — Padel Medina
# Copia este archivo a .env (frontend) y configura los SECRETS de las Edge
# Functions en Supabase Dashboard > Project Settings > Edge Functions > Secrets.
# NUNCA subas claves reales al repo. Solo las VITE_* llegan al navegador.
# ============================================================================

# ── Frontend (Vite) — van al bundle del navegador ──
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_publica
VITE_VAPID_PUBLIC_KEY=tu_vapid_public_key   # notificaciones push (PWA)

# ============================================================================
# SECRETS de Edge Functions (Supabase) — NO usan prefijo VITE_, no van al cliente
# ============================================================================

# ── Supabase (las inyecta Supabase automáticamente en las functions) ──
# SUPABASE_URL=...
# SUPABASE_SERVICE_ROLE_KEY=...   # service_role: bypassa RLS. SECRETO ABSOLUTO.

# ── App ──
APP_URL=https://padelmedina.com          # base para enlaces de email y retornos de pago

# ── Email (Resend) ──
RESEND_API_KEY=re_xxx
SHOP_NOTIFY_EMAIL=info@padelmedina.com    # (tienda) email del club que recibe avisos de venta

# ── Redsys (TPV Virtual + Bizum) ──
REDSYS_MERCHANT_CODE=xxxxxxxxx            # FUC / código de comercio
REDSYS_TERMINAL=1                         # número de terminal
REDSYS_SECRET_KEY=clave_secreta_sha256_base64
# Conmutar entorno de pago de la TIENDA (shop-create-order):
#   TEST: https://sis-t.redsys.es:25443/sis/realizarPago
#   PROD: https://sis.redsys.es/sis/realizarPago  (valor por defecto si se omite)
REDSYS_URL=https://sis-t.redsys.es:25443/sis/realizarPago
